{% extends 'base.html.twig' %}
{% block body %}
    {% if authentication_error %}
        <div class="alert alert-danger mt-2 mb-2">
            <i class="fa-solid fa-triangle-exclamation"></i> {{ authentication_error.messageKey | trans(authentication_error.messageData, 'security') }}
        </div>
    {% endif %}

    {{ form_start(login_form) }}
    <fieldset class="mt-3">
        <legend>Connexion:</legend>
        <div class="mb-3">
            {{ form_row(login_form.username, {
                label_attr : {
                    class : 'form-label'
                },
                attr: {
                    class: 'form-control'
                }
            }) }}
        </div>
        <div class="mb-3">
            {{ form_row(login_form.password, {
                label_attr : {
                    class : 'form-label'
                },
                attr: {
                    class: 'form-control'
                }
            }) }}
        </div>
        <div class="mb-3">
            {{ form_row(login_form.agency, {
                label_attr : {
                    class : 'form-label'
                },
                attr: {
                    class: 'form-control'
                }
            }) }}
        </div>
        <div class="mb-3">
            <button type="submit" class="btn btn-sm btn-success">
                <i class="fa-solid fa-arrow-right-to-bracket"></i> Login
            </button>
        </div>
    </fieldset>
    {{ form_end(login_form) }}
{% endblock %}
