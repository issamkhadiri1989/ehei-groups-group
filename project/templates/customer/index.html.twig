{% extends 'base.html.twig' %}

{% block title %}Hello CustomerController!{% endblock %}

{% block body %}
        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-body p-4">
                <div class="d-flex align-items-center gap-3">
                    <div>
                        <h5 class="mb-0">
                            {{ customer.firstName }} {{ customer.lastName }}
                        </h5>
                    </div>
                </div>

                <hr class="my-3">

                <div class="row g-2" style="font-size:14px;">
                    <div class="col-5 text-muted">Phone</div>
                    <div class="col-7">{{ customer.phone }}</div>

                    <div class="col-5 text-muted">Email</div>
                    <div class="col-7 text-primary">j.carter@email.com</div>

                    <div class="col-5 text-muted">Adresse: </div>
                    <div class="col-7">{{ customer.address }}</div>

                    <div class="col-5 text-muted">Ville : </div>
                    <div class="col-7">{{ customer.city }}</div>

                    <div class="col-5 text-muted">Code postal : </div>
                    <div class="col-7">{{ customer.zipCode }}</div>
                </div>
            </div>
        </div>

        <!-- Accounts -->
        <h6 class="text-muted text-uppercase mb-3" style="font-size:11px;letter-spacing:.06em;">
            Accounts ({{ customer.accounts | length }})
        </h6>

        <div class="row g-3">
            {% for account in customer.accounts %}
                <div class="col-12">
                    <div class="card border-0 shadow-sm rounded-4">
                        <div class="card-body p-3">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <div class="fw-medium">Checking</div>
                                    <small class="text-muted">{{ account.number }}</small>
                                </div>
                                {% if account.isActive is same as (true) %}
                                    <span class="badge bg-success">Active</span>
                                {% else %}
                                    <span class="badge bg-dark">Inactive</span>
                                {% endif %}
                            </div>
                            <h4 class="fw-semibold mb-0">{{ account.balance | number_format(2, ',', ' ') }} DHS</h4>
                            <small class="text-muted">Created: {{ account.creationDate | date('F, d Y') }}</small>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
{% endblock %}
