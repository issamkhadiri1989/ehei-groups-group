{% extends 'base.html.twig' %}
{% block body %}
    {% if authentication_error %}
        <div class="alert alert-danger mt-2 mb-2">
            <i class="fa-solid fa-triangle-exclamation"></i> {{ authentication_error.messageKey | trans(authentication_error.messageData, 'security') }}
        </div>
    {% endif %}

<form method="post" action="{{ url('app_security_2fa') }}">
    <fieldset class="mt-3">
        <legend>Saisir le code pin recu par mail:</legend>
        <div class="mb-3">
            <label class="form-label" for="pin_code">Code pin :</label>
            <input type="text" class="form-control" name="pin_code" id="pin_code"/>
        </div>

        <input type="hidden"
               name="_csrf_token"
               value="{{ csrf_token('__2fa_token__') }}"
        />

        <div class="mb-3">
            <button type="submit" class="btn btn-sm btn-success">
                <i class="fa-solid fa-arrow-right-to-bracket"></i> Login
            </button>
        </div>
    </fieldset>
</form>
{% endblock %}
